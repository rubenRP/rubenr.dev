---
import { getCollection } from "astro:content";
import BlogList from "../../../components/BlogList.vue";
import Hero from "../../../components/Hero.vue";
import Layout from "../../../layouts/Layout.astro";

const heroClasses = "text-light hero-tiny gradient-animation";
const textAlign = "text-left";
const normalizeIdToSlug = (id: string) => id.replace(/\.mdx?$/, "");

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  const tags = allPosts
    .map((post: any) => post.data.taxonomy?.tag || [])
    .flat();

  const uniqueTags = [...new Set(tags.map((tag: string) => tag.toLowerCase()))];

  return uniqueTags.map((tag: string) => ({
    params: { tag },
    props: {
      posts: allPosts.filter((post: any) =>
        post.data.taxonomy?.tag
          ?.map((tag: string) => tag.toLowerCase())
          .includes(tag),
      ),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

const enPosts = posts
  .filter((post: any) => post.id.startsWith("en/"))
  .map((post: any) => {
    const normalizedId = normalizeIdToSlug(post.id);
    return { ...post, slug: `/${normalizedId.slice(3)}` };
  });
const esPosts = posts
  .filter((post: any) => post.id.startsWith("es/"))
  .map((post: any) => {
    const normalizedId = normalizeIdToSlug(post.id);
    return { ...post, slug: `/es/${normalizedId.slice(3)}` };
  });
---

<Layout title={`Posts tagged with "${tag}"`}>
  <Hero
    title={`Tag: "${tag}"`}
    text-align={textAlign}
    hero-classes={heroClasses}
  />
  <section id="start"></section>
  <BlogList enPosts={enPosts} esPosts={esPosts} client:visible />
</Layout>
