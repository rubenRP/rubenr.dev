{
  "name": "rubenr.dev",
  "type": "module",
  "description": "Personal website and blog made with Astro",
  "version": "4.0.0",
  "author": "Rubén Rodríguez <hola@rubenr.dev>",
  "bugs": {
    "url": "https://github.com/rubenRP/rubenr.dev/issues"
  },
  "homepage": "https://github.com/rubenRP/rubenr.dev#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rubenRP/rubenr.dev.git"
  },
  "keywords": [
    "astro",
    "vue",
    "blog",
    "personal",
    "website"
  ],
  "license": "MIT",
  "private": true,
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.8.2"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint . --ext .js,.mjs,.ts,.vue,.astro",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run check && npm run build"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vue": "^6.0.1",
    "@iconify-icons/mdi": "^1.2.48",
    "@iconify/vue": "^4.3.0",
    "ackee-tracker": "^5.1.3",
    "astro": "^6.1.8",
    "sass": "^1.99.0",
    "typed.js": "^2.1.0",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/ackee-tracker": "^5.0.4",
    "@typescript-eslint/parser": "^8.58.2",
    "astro-eslint-parser": "^1.0.3",
    "eslint": "^8.57.1",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "^6.0.3",
    "vue-eslint-parser": "^10.4.0"
  }
}
