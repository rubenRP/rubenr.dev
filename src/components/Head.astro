---
import { SITE_METADATA } from "../const/site";

const {
  title,
  description,
  image = "/icons/favicon-32x32.png",
  hreflang,
  structuredData,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const absoluteImage = new URL(image, Astro.site ?? Astro.url);
const defaultStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_METADATA.siteTitle,
  url: new URL("/", Astro.site ?? Astro.url).toString(),
  description: SITE_METADATA.siteDescription,
};

interface Props {
  title: string;
  description: string;
  image?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  hreflang?: Array<{
    lang: string;
    url: string;
  }>;
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" href="/icons/favicon-32x32.png" />
<meta name="generator" content={Astro.generator} />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link
  rel="preconnect"
  href="https://fonts.gstatic.com"
  crossorigin="anonymous"
/>
<link
  href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=IBM+Plex+Mono:wght@400;600&family=Space+Grotesk:wght@400;500;700&display=swap"
  rel="stylesheet"
/>

<!-- Icons -->
<link rel="apple-touch-icon" href="/icons/icon-48x48.png" sizes="48x48" />
<link rel="apple-touch-icon" href="/icons/icon-72x72.png" sizes="72x72" />
<link rel="apple-touch-icon" href="/icons/icon-96x96.png" sizes="96x96" />
<link rel="apple-touch-icon" href="/icons/icon-144x144.png" sizes="144x144" />
<link rel="apple-touch-icon" href="/icons/icon-192x192.png" sizes="192x192" />
<link rel="apple-touch-icon" href="/icons/icon-256x256.png" sizes="256x256" />
<link rel="apple-touch-icon" href="/icons/icon-384x384.png" sizes="384x384" />
<link rel="apple-touch-icon" href="/icons/icon-512x512.png" sizes="512x512" />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImage} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={absoluteImage} />

<!-- hreflang -->
{
  hreflang &&
    hreflang.map(({ lang, url }) => (
      <link
        rel="alternate"
        hreflang={lang}
        href={new URL(url, Astro.site ?? Astro.url)}
      />
    ))
}

<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify(defaultStructuredData)}
/>
{
  structuredData &&
    (Array.isArray(structuredData) ? structuredData : [structuredData]).map(
      (item) => (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(item)}
        />
      ),
    )
}

<link rel="sitemap" href="/sitemap-index.xml" />
